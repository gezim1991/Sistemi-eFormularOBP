FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Build TanStack Start / Nitro for Node.js target
RUN npm run build

# ── Runtime stage ──
FROM node:20-alpine

WORKDIR /app

# Copy only the nitro build output
COPY --from=builder /app/.output ./.output

ENV NODE_ENV=production \
    PORT=3000 \
    HOST=0.0.0.0

EXPOSE 3000

CMD ["node", ".output/server/index.mjs"]
